# Database Configuration
DB_PATH=ledger.db
LOAD_SEED_DATA=false
DB_SLOW_QUERY_MS=80

# Security & Session Configuration (CHANGE THESE IN PRODUCTION!)
SESSION_SECRET=generate-a-random-32-character-string-here
JWT_SECRET=generate-a-random-32-character-string-here
SESSION_COOKIE_NAME=gbl_session
SESSION_TTL_MINUTES=480
SESSION_COOKIE_SECURE=auto
ENABLE_HSTS=auto

# Initial Admin User (CHANGE THESE IN PRODUCTION!)
OWNER_USERNAME=admin
OWNER_PASSWORD=ChangeMe@123

# Web Server Configuration
HOST=127.0.0.1
PORT=8000
DEBUG=false

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15
CSRF_HEADER_NAME=X-CSRF-Token
